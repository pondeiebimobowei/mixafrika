{
  "name": "@mixafrica/backend",
  "version": "0.0.1",
  "description": "<p align=\"center\">\r   <a href=\"http://nestjs.com/\" target=\"blank\"><img src=\"https://nestjs.com/img/logo-small.svg\" width=\"120\" alt=\"Nest Logo\" /></a>\r </p>",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/backend/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "pretest:e2e": "npm run clear:test",
    "test:e2e": "dotenv -e .env.test -- jest --no-cache --config ./test/jest-e2e.json",
    "migrate:test": "dotenv -e .env.test -- cross-env NODE_ENV=test npx sequelize-cli db:migrate",
    "migrate:undo:test": "dotenv -e .env.test -- sequelize-cli db:migrate:undo",
    "migrate:undo:all:test": "dotenv -e .env.test -- sequelize-cli db:migrate:undo:all",
    "migrate:seed:all:test": "dotenv -e .env.test -- sequelize-cli db:seed:all",
    "migrate:seed:undo:test": "dotenv -e .env.test -- sequelize-cli db:seed:undo",
    "clear:test": "dotenv -e .env.test -- sequelize-cli db:seed:undo:all && dotenv -e .env.test -- sequelize-cli db:seed:all",
    "reset:test": "dotenv -e .env.test -- sequelize-cli db:migrate:undo:all && dotenv -e .env.test -- sequelize-cli db:migrate && dotenv -e .env.test sequelize-cli db:seed:all",
    "migrate": "dotenv -- sequelize-cli db:migrate",
    "migrate:prod": "dotenv -e .env -- cross-env NODE_ENV=production npx sequelize-cli db:migrate",
    "migrate:undo": "dotenv -- sequelize-cli db:migrate:undo",
    "migrate:undo:all": "dotenv -- sequelize-cli db:migrate:undo:all",
    "migrate:seed:all": "dotenv -- sequelize-cli db:seed:all",
    "migrate:seed:undo": "dotenv -- sequelize-cli db:seed:undo",
    "reset": "dotenv -e .env -- cross-env NODE_ENV=development sequelize-cli db:migrate:undo:all && dotenv -e .env -- sequelize-cli db:migrate && dotenv -e .env -- sequelize-cli db:seed:all",
    "migrate:skeleton": "sequelize-cli migration:generate --name migration-skeleton"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/sequelize": "^11.0.1",
    "bcrypt": "^6.0.0",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^10.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.7",
    "sequelize-typescript": "^2.1.6",
    "ts-node": "^10.9.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "sequelize-cli": "^6.6.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "keywords": [],
  "type": "commonjs"
}
