{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@shared/shared/src/(.*)$": "<rootDir>/../../packages/shared/src/$1",
    "^@shared/(.*)$": "<rootDir>/../../packages/$1"
  }
}
