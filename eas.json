{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "distribution": "internal"
      },
      "env": {
        "COREPACK_ENABLED": "true",
        "YARN_ENABLE_IMMUTABLE_INSTALLS": "false"
      },
      "node": "18.18.0",
      "commands": {
        "preinstall": "corepack enable && corepack prepare yarn@4.12.0 --activate"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
