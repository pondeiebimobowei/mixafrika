DB_NAME=mixafrica
DB_USER=mixafrica
DB_PASS=change-me
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

CLOUDINARY_API_KEY=change-me
CLOUDINARY_API_SECRET=change-me
CLOUDINARY_CLOUD_NAME=change-me

access_token_secret=change-me
refresh_token_secret=change-me

# Optional. Leave unset to use the same-origin /api proxy through the frontend container.
VITE_API_ENDPOINT=/api

# Build-time API URL for the Flutter web app.
# Changing this requires a new Coolify image build for spine-web.
BASE_URL=https://api.mixafrika.com/v1

# Build-time API base URL for spineweb.
# Set this in your env file for the target environment.
VITE_API_BASE_URL=

# Optional. Only needed if you expose the backend directly instead of proxying through the frontend.
CORS_ORIGINS=https://your-frontend-domain.example,https://your-second-domain.example
